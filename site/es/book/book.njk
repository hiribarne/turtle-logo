---
pagination:
  data: chapters_es
  size: 1
  alias: chapter
permalink: "es/book/{{ chapter.slug }}/"
eleventyComputed:
  title: "{{ chapter.title }}"
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ chapter.title }} — Turtle Logo</title>
  <meta name="description" content="El Libro de la Tortuga — {{ chapter.title }}">
  <link rel="stylesheet" href="{{ base }}/assets/css/base.css">
  <link rel="stylesheet" href="{{ base }}/assets/css/book.css">
</head>
<body>
  {% set lang = 'es' %}
  {% set altUrl = '/book/' %}
  {% include "partials/nav.njk" %}

  <div class="chapter-layout">
    {% if chapter.hasCode %}
    <div class="chapter-turtle">
      <div class="chapter-canvas-wrap" id="chapter-canvas-wrap">
        <canvas id="chapter-drawing"></canvas>
        <canvas id="chapter-sprite"></canvas>
      </div>
      <script>
        (function() {
          var wrap = document.getElementById('chapter-canvas-wrap');
          var w = wrap.clientWidth, h = wrap.clientHeight;
          ['chapter-drawing','chapter-sprite'].forEach(function(id) {
            var c = document.getElementById(id);
            c.width = w; c.height = h;
          });
        })();
      </script>
      <div class="chapter-turtle-bar">
        <div class="chapter-output" id="chapter-output"></div>
        <button class="lang-toggle-btn" id="chapter-lang-btn" title="Cambiar idioma">ES</button>
        <button class="chapter-reset-btn" id="chapter-reset" title="Borrar pantalla y reiniciar">Reiniciar</button>
      </div>
      <div class="chapter-input-row">
        <span class="chapter-prompt">?&gt;</span>
        <input type="text" id="chapter-cmd-input" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="Escribe un comando...">
      </div>
    </div>
    {% endif %}

    <div class="chapter-content">
      <h1>{{ chapter.title }}</h1>
      {{ chapter.html | safe }}

      <div class="chapter-nav">
        {% if chapter.prev %}
          <a href="{{ base }}/es/book/{{ chapter.prev.slug }}/">&larr; {{ chapter.prev.title }}</a>
        {% else %}
          <span></span>
        {% endif %}
        {% if chapter.next %}
          <a href="{{ base }}/es/book/{{ chapter.next.slug }}/">{{ chapter.next.title }} &rarr;</a>
        {% else %}
          <a href="{{ base }}/es/book/">Volver al &Iacute;ndice</a>
        {% endif %}
      </div>
    </div>
  </div>

  <footer class="site-footer">Turtle Logo &copy; 2026</footer>
  {% if chapter.hasCode %}
  <script type="module" src="{{ base }}/assets/js/code-block.js"></script>
  {% endif %}
</body>
</html>
